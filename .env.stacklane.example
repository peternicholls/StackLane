# Stacklane stack-defaults file.
# Copy this file to `.env.stacklane` in your stack-home directory
# (the directory that contains your project folders) and adjust as needed.
#
# Variables defined here apply to every project under this stack-home,
# unless overridden by a project's `.stacklane-local` or by a CLI flag.
#
# NOTE (FR-016): STACKLANE_POST_UP_COMMAND is intentionally NOT honored
# here. Post-up hooks must be declared in each project's `.stacklane-local`
# so that one project cannot smuggle commands into another.

# First-stage hostname policy
# Use .test (default) for zero-friction HTTP-only local dev.
# Use .dev for HSTS-preloaded TLS — requires mkcert (brew install mkcert && mkcert -install)
SITE_SUFFIX=test
# SITE_SUFFIX=dev

# Runtime defaults
PHP_VERSION=8.5
MYSQL_VERSION=10.6
MYSQL_ROOT_PASSWORD=root

# Shared gateway defaults (single shared compose project: stacklane-shared)
# SHARED_GATEWAY_HTTP_PORT=80
# SHARED_GATEWAY_HTTPS_PORT=443
# Local .dev defaults to 8443 unless you pin SHARED_GATEWAY_HTTPS_PORT.
# SHARED_GATEWAY_NETWORK=stacklane-shared
# SHARED_GATEWAY_COMPOSE_PROJECT_NAME=stacklane-shared

# Local DNS defaults
# LOCAL_DNS_PROVIDER=dnsmasq
# LOCAL_DNS_IP=127.0.0.1
# LOCAL_DNS_PORT=53535
# LOCAL_DNS_SUFFIX=test

# Per-project published service ports (defaults for every project)
# MYSQL_PORT=3306
# PMA_PORT=8081

# Optional stack-wide defaults for project config resolution.
# Per-project .stacklane-local and CLI flags take precedence.
# DOCROOT=public_html
# MYSQL_DATABASE=my_project
# MYSQL_USER=my_project
# MYSQL_PASSWORD=devpass
